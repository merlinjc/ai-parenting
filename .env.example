# AI Parenting — 环境变量配置模板
#
# 复制为 .env 并填入真实值：
#   cp .env.example .env
#
# 注意：.env 文件不应提交到版本控制！

# =========================================================================
# 后端配置
# =========================================================================

# 服务端口
BACKEND_PORT=8000

# 数据库（开发环境用 SQLite，生产用 PostgreSQL）
# DATABASE_URL=sqlite+aiosqlite:///./data/ai_parenting.db
# DATABASE_URL=postgresql+asyncpg://aip:password@postgres:5432/ai_parenting

# AI 模型 (mock / hunyuan)
AI_PROVIDER=mock
HUNYUAN_API_KEY=
HUNYUAN_BASE_URL=
HUNYUAN_MODEL=

# JWT 认证密钥（生产环境必须修改！）
JWT_SECRET=dev-secret-change-in-production

# =========================================================================
# APNs 推送
# =========================================================================
APNS_BUNDLE_ID=
APNS_KEY_PATH=/app/certs/apns_key.p8
APNS_KEY_PATH_HOST=./certs/apns_key.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_USE_SANDBOX=true

# =========================================================================
# 微信服务号
# =========================================================================
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_AES_KEY=

# =========================================================================
# OpenClaw Gateway
# =========================================================================

# Gateway WebSocket（Docker 内部自动设为 ws://gateway:8765）
# 本地开发时可设为 ws://localhost:8765
OPENCLAW_API_KEY=your-openclaw-api-key

# Gateway 端口映射
GATEWAY_WS_PORT=8765
GATEWAY_HTTP_PORT=18789

# 渠道开关
WHATSAPP_ENABLED=false
TELEGRAM_ENABLED=false

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=

# Webhook 回调地址（Docker 内部自动设为 http://backend:8000/api/v1/webhooks/openclaw）
WEBHOOK_URL=http://backend:8000/api/v1/webhooks/openclaw

# =========================================================================
# PostgreSQL（生产环境 —— docker compose --profile production up）
# =========================================================================
POSTGRES_DB=ai_parenting
POSTGRES_USER=aip
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432
